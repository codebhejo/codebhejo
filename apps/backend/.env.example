APP_NAME=CodeBhejo
PORT=3000
FRONTEND_URL="http://localhost:5173"

# Generate any random string for local dev, e.g.: openssl rand -hex 32
JWT_SECRET=""

# Database — matches docker-compose.yml defaults
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_USER="root"
DB_PASSWORD="root"
DB_NAME="codebhejo"

# Storage — MinIO via docker-compose.yml (S3-compatible, no AWS account needed)
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="codebhejo"
S3_REGION="us-east-1"
S3_ENDPOINT="http://localhost:9000"

# Email — Mailpit via docker-compose.yml (catches all mail, no real emails sent)
# View sent emails at http://localhost:8025
MAIL_PROVIDER="smtp"
MAIL_FROM="no-reply@codebhejo.in"
SMTP_HOST="localhost"
SMTP_PORT="1025"

# For production (SES), replace the above with:
# MAIL_PROVIDER="ses"
# AWS_REGION=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
